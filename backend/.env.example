PORT=3000

# Firebase Admin SDK - download from Firebase Console > Project Settings > Service Accounts
# Preferred local setup: put the downloaded service-account JSON in backend/ and point to it here.
# Example:
# GOOGLE_APPLICATION_CREDENTIALS=serviceAccountKey.json

# Or provide the three fields below directly:
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_CLIENT_EMAIL=your-client-email@project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
