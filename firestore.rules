rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Lock down by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Profiles — own-user read/write, admin read/update for moderation
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, update: if isAdmin();
    }

    // Trips
    match /trips/{tripId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.driverId;
    }

    // Ride Requests
    match /rideRequests/{requestId} {
      allow read: if request.auth != null && (
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.tripOwnerId
      );
      allow create: if request.auth != null;
      allow update: if request.auth != null && (
        request.auth.uid == resource.data.passengerId ||
        request.auth.uid == resource.data.tripOwnerId
      );
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.recipientId;
      // Allow authenticated users to create notifications for others (e.g. driver for passenger)
      allow create: if request.auth != null;
      allow update: if request.auth != null && request.auth.uid == resource.data.recipientId;
    }

    // Push Tokens
    match /pushTokens/{tokenId} {
      allow read, write: if request.auth != null && request.auth.uid == request.resource.data.userId;
      // For existing docs on read
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    // Vehicles
    match /vehicles/{vehicleId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == request.resource.data.ownerId;
      allow read, update, delete: if request.auth != null && request.auth.uid == resource.data.ownerId;
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read, create: if request.auth != null;
    }

    // Reports — admin read/update for moderation dashboard
    match /reports/{reportId} {
      allow read: if isAdmin();
      allow update: if isAdmin();
    }

    // Audit logs — admin append-only
    match /auditLogs/{logId} {
      allow create: if isAdmin();
    }
  }
}
